PORT=8787
DATABASE_URL=postgresql://economic:economic@localhost:5432/economic_data?schema=public
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173
ENABLE_SCHEDULER=false
# Optional comma-separated YYYY-MM-DD policy-rate release dates used before the 42-day fallback cadence.
POLICY_RATE_RELEASE_DATES=
# Copy this file to backend/.env and paste your real FRED API key here.
FRED_API_KEY=
# Free registration official API for Japan.
ESTAT_APP_ID=
# Japan e-Stat fields use Statistics Dashboard 19-digit IndicatorCode values.
ESTAT_GDP_STATS_DATA_ID=
ESTAT_GDP_NOMINAL_STATS_DATA_ID=
ESTAT_CPI_STATS_DATA_ID=
# Optional China NBS EasyQuery direct reads. Disabled by default because deployment reachability varies.
NBS_DIRECT_ENABLED=false
NBS_DIRECT_TIMEOUT_MS=8000
# Exact dates can also be committed in src/data/releaseCalendar.ts.
# Environment values take precedence, for example:
# US_CPI_RELEASE_DATES=2026-07-14T12:30:00.000Z,2026-08-12T12:30:00.000Z
